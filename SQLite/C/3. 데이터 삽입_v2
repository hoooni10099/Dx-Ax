#include <stdio.h>
#include <sqlite3.h>

int main()
{
    sqlite3 *db;
    char *errMsg = NULL;
    
    if (sqlite3_open("/home/smart/work/dbfiles/car.db", &db) != SQLITE_OK) {
        printf("DB 열기 실패\n");
        return 1;
    }

    const char *sql = "INSERT INTO car VALUES"
                        "('0123', 'Toyota', '2026-01-01 00:00:00', '2026-01-01 00:10:00'),"
                        "('1234', 'Honda', '2026-01-01 00:03:14', '2026-01-01 00:25:00'),"
                        "('2345', 'Santafe', '2026-01-04 04:10:00', '2026-01-06 08:15:00'),"
                        "('3456', 'Ford', '2026-01-23 15:20:00', '2026-01-27 19:20:20'),"
                        "('4567', 'BMW', '2026-01-21 16:20:00', '2026-01-27 22:42:10');";
    
    if (sqlite3_exec(db, sql, NULL, NULL, &errMsg) != SQLITE_OK) {
        printf("데이터 삽입 실패 : %s\n", errMsg);
        sqlite3_free(errMsg);
    }
    else {
        printf("데이터 삽입 완료\n");
    }

    sqlite3_close(db);

    return 0;
}
