import sqlite3

def main():

    sql = """
    INSERT INTO Order_Items VALUES
    (1,1,'Keyboard',2,50000),
    (2,1,'Mouse',1,30000),
    (3,2,'Monitor',1,250000),
    (4,3,'USB',5,10000);
"""

    with sqlite3.connect("/home/smart/work/dbfiles/test1.db") as conn:

        cursor = conn.cursor()

        cursor.execute(sql)

        conn.commit()

        print("데이터 삽입 완료")

if __name__ == "__main__":
    main()
