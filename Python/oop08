class Student:
    def __init__(self, name = '학생', age = 18):
        self.__name = name
        self.__age = age

    @property
    def name(self):
        return self.__name
    @name.setter
    def name(self, value):
        # 암호화, 압축, 보안, 동기화, 로그
        self.__name = value
    
    @property
    def age(self):
        return self.__age
    @age.setter
    def age(self, value):
        self.__age = value

hong = Student()
hong.name = '홍길동'
print(hong.name) #property 사용

hong.age = 20
print(hong.age)

print(hong.__dict__)
