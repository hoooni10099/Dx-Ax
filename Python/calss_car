class car:
    def __init__(self, speed, color, model):
        self.speed = speed
        self.color = color
        self.model = model

    def speed_up(self):
        self.speed = 60

myCar = car(0, 'blue', 'Ford')

print('자동차의 속도 : ', myCar.speed)
print('자동차의 색상 : ', myCar.color)
print('자동차의 모델 : ', myCar.model)

myCar.speed_up()
print('자동차의 속도 : ', myCar.speed)
