#include <stdio.h>

int main()
{
    char str[100];
    int count = 0;
    int i = 0;

    printf("문자열을 입력하세요 : ");
    scanf("%s", str);

    while (str[i] != '\0') {
        if (str[i] >= 'A' && str[i] <= 'Z') {
            count++;
        }
        i++;
    }

    printf("대문자 개수 : %d\n", count);

    return 0;
}
