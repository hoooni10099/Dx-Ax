#include <stdio.h>
#include <stdlib.h>

// 동적 할당 영역을 배열처럼 쓰기

int main()
{
    int *arr;

    arr = (int *)malloc(sizeof(int) * 10); //40bytes 공간 확보

    // 입력
    for (int i = 0; i < 10; i ++) {
        arr[i] = i + 1;
    }

    // 출력
    for (int i = 0; i < 10; i ++) {
        printf("%5d", arr[i]);
    }
    printf("\n");
    free(arr);

    return 0;
}
