#include <stdio.h>
#include <string.h>

int main()
{
    char name[100], date[100], LOT[100];

    printf("제품명 : ");
    scanf("%s", name);

    printf("생산일 : ");
    scanf("%s", date);

    strcpy(LOT, name);
    strcat(LOT, "_");
    strcat(LOT, date);

    printf("LOT 번호 : %s\n", LOT);
    return 0;
}
