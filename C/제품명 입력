#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main()
{
    char temp[100];

    printf("제품명 입력 : ");
    fgets(temp, sizeof(temp), stdin);

    temp[strcspn(temp, "\n")] = '\0';

    char *product =
        (char *)malloc(strlen(temp) + 1);

    if(product == NULL)
    {
        printf("메모리 할당 실패\n");
        return 1;
    }

    strcpy(product, temp);

    printf("저장된 제품명 : %s\n", product);

    free(product);

    return 0;
}
