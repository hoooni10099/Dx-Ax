#include <stdio.h>

int main()
{
    int a;
    int sum = 0;

    printf("1000 이하의 자연수를 입력하세요 : ");
    scanf("%d", &a);

    for (int i = 1; i < a; i++) {
        if (a % i == 0) { 
            sum += i;     
        }
    }

    if (sum == a) {
        printf("yes\n");
    } else {
        printf("no\n");
    }

    return 0;
}
